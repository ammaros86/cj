def check_existing_files(self, class_name, usages):
        """
        Prüft, ob Interface, Wrapper und Mock existieren und ob alle 
        genutzten Methoden darin vorkommen.
        """
        base = "generate"
        paths = [
            os.path.join(base, "interfaces", f"I{class_name}.h"),
            os.path.join(base, "wrappers", f"{class_name}Wrapper.h"),
            os.path.join(base, "mocks", f"{class_name}Mock.h")
        ]
        
        # Wenn eine der Dateien fehlt, müssen wir generieren
        for p in paths:
            if not os.path.exists(p):
                return False, []
        
        # Methoden-Namen aus den Usages extrahieren (z.B. "Foo::bar" -> "bar")
        method_names = set()
        for u in usages:
            # Einfacher Regex-Check, um potenzielle Methodennamen zu finden
            matches = re.findall(rf'{class_name}::(\w+)', u)
            for m in matches:
                method_names.add(m)
                
        # Prüfe, ob die Methoden im existierenden Interface stehen
        missing_methods = []
        with open(paths[0], "r", encoding="utf-8") as f:
            interface_content = f.read()
            
        for method in method_names:
            # Wenn der Methodenname nicht im Interface-Code existiert
            if method not in interface_content:
                missing_methods.append(method)
                
        return True, missing_methods

    def get_existing_files_code(self, class_name):
        """Liest den aktuellen Code der 3 Dateien aus."""
        base = "generate"
        sections = {"interface": "", "wrapper": "", "mock": ""}
        
        p_int = os.path.join(base, "interfaces", f"I{class_name}.h")
        p_wrap = os.path.join(base, "wrappers", f"{class_name}Wrapper.h")
        p_mock = os.path.join(base, "mocks", f"{class_name}Mock.h")
        
        if os.path.exists(p_int):
            with open(p_int, "r", encoding="utf-8") as f: sections["interface"] = f.read()
        if os.path.exists(p_wrap):
            with open(p_wrap, "r", encoding="utf-8") as f: sections["wrapper"] = f.read()
        if os.path.exists(p_mock):
            with open(p_mock, "r", encoding="utf-8") as f: sections["mock"] = f.read()
            
        return sections

