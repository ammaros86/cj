if __name__ == "__main__":
    test_file = "TestHeader.h"
    with open(test_file, "w", encoding="utf-8") as f:
        f.write("""
        class MyClass {
        public:
            void setData(int value, const char* name);
            int compute();
            int compute(int factor); // Überladung!
            
            class InnerClass {
            public:
                void innerMethod(double x);
            };
            
        private:
            void secret(); // Wird ignoriert, da nicht public
        };
        """)

    parser = HeaderParser(test_file)
    result = parser.parse()
    
    # Ausgabe des erzeugten Dictionaries
    print("\nAusgabe-JSON:")
    print(json.dumps(result, indent=4))

    if os.path.exists(test_file):
        os.remove(test_file)
